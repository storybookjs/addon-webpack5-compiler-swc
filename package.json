{
  "name": "@storybook/addon-webpack5-compiler-swc",
  "version": "4.0.3",
  "type": "module",
  "description": "Adds SWC as a Webpack5 compiler to Storybook",
  "keywords": [
    "storybook-addons",
    "webpack5",
    "swc"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storybookjs/addon-webpack5-compiler-swc.git"
  },
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "format": "biome format ./src",
    "format:write": "pnpm format --write",
    "check": "biome check ./src",
    "check:apply": "pnpm check --apply",
    "check:apply-unsafe": "pnpm check --apply-unsafe",
    "check:ci": "biome ci ./src",
    "release": "pnpm build && pnpm changeset publish"
  },
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./preset": "./dist/preset.cjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "files": [
    "dist/**/*",
    "preset.js",
    "src/**/*",
    "README.md"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "storybook": {
    "displayName": "Addon Webpack5 Compiler SWC",
    "supportedFrameworks": [
      "react",
      "preact",
      "vue",
      "web-components",
      "html",
      "svelte"
    ]
  },
  "dependencies": {
    "@swc/core": "^1.13.5",
    "swc-loader": "^0.2.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.6",
    "pkg-pr-new": "^0.0.57",
    "storybook": "^9.1.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "webpack": "^5.101.3"
  },
  "peerDependencies": {
    "storybook": "^0.0.0-0 || ^9.0.0 || ^10.0.0-0 || ^10.1.0-0 || ^10.2.0-0 || ^10.3.0-0 || ^10.4.0-0 || ^10.5.0-0 || ^10.6.0-0"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Storybook Bot <storybookbot@gmail.com>",
  "bundler": {
    "exportEntries": [
      "src/index.ts"
    ],
    "nodeEntries": [
      "src/preset.ts"
    ]
  },
  "packageManager": "pnpm@10.12.4"
}
